---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Eventio | Dashboard Detail"
  description="View event details, join events, and manage your participation."
>
  <main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-6xl">
      <div class="mb-4 inline-flex rounded-md border border-slate-200 bg-white p-1 text-xs font-semibold sm:text-sm">
        <span class="primary-btn rounded-md px-3 py-2">03-1-1-Detail</span>
        <a href="/dashboard-detail-joined" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-2-Detail-Joined</a>
        <a href="/dashboard-detail-edit" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-3-Detail-Edit</a>
      </div>
    </div>
    <div class="mx-auto grid w-full max-w-6xl gap-6 lg:grid-cols-[2fr_1fr]">
      <section class="surface-card p-5 sm:p-7">
        <p class="eyebrow">Event detail</p>
        <h1 class="type-title mt-2">Summer Product Festival</h1>
        <p class="type-body mt-3 text-slate-600">
          A full day of talks, networking, and hands-on workshops from local product teams.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <button type="button" class="primary-btn px-4 py-2 text-sm font-semibold">Join Event</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Edit Event</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Back to Dashboard</button>
        </div>
        <div class="mt-7 grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Agenda</p>
            <p class="mt-2 text-sm text-slate-700">Keynotes, case studies, networking dinner.</p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-[0.14em] text-slate-500">Capacity</p>
            <p class="mt-2 text-sm text-slate-700">124 / 150 spots reserved.</p>
          </div>
        </div>
      </section>
      <aside class="surface-card p-5">
        <h2 class="text-lg font-semibold">Event facts</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>Date: 14 Aug 2026</li>
          <li>Time: 17:00</li>
          <li>Location: Vienna</li>
          <li>Attendees: 124</li>
        </ul>
      </aside>
    </div>
  </main>
</MainLayout>
