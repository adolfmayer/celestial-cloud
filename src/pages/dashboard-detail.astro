---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Eventio | Dashboard Detail">
  <main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
    <div class="mx-auto grid w-full max-w-6xl gap-6 lg:grid-cols-[2fr_1fr]">
      <section class="surface-card p-5 sm:p-7">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-violet-600">03-1-1 / 03-1-2 / 03-1-3</p>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight sm:text-3xl">Summer Product Festival</h1>
        <p class="mt-3 text-sm text-slate-600 sm:text-base">
          Static representation of detail, joined, and edit variants. Buttons are visual-only for V1.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <button type="button" class="rounded-xl bg-violet-700 px-4 py-2 text-sm font-semibold text-white">Join Event</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Edit Event</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Back to Dashboard</button>
        </div>
      </section>
      <aside class="surface-card p-5">
        <h2 class="text-lg font-semibold">Event facts</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>Date: 14 Aug 2026</li>
          <li>Time: 17:00</li>
          <li>Location: Vienna</li>
          <li>Attendees: 124</li>
        </ul>
      </aside>
    </div>
  </main>
</MainLayout>
