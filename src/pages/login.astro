---
import AuthCard from "../components/AuthCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Eventio | Log In">
  <main class="flex min-h-screen items-center px-4 py-12 sm:px-6">
    <div class="mx-auto w-full max-w-5xl">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <section>
          <p class="eyebrow">LOG IN</p>
          <h2 class="type-hero mt-4">Discover events that fit your vibe.</h2>
          <p class="type-body mt-3 max-w-md text-slate-600">Access your account and continue where you left off.</p>
          <div class="mt-7 flex gap-3 text-xs font-semibold text-slate-500">
            <span class="rounded-full bg-white px-3 py-1.5">01-1-1-Sign-In</span>
            <span class="rounded-full bg-white px-3 py-1.5">01-1-2-Sign-In</span>
          </div>
        </section>
        <AuthCard
          title="Welcome back"
          subtitle="Log in to continue managing your events."
          cta="Log In"
          footerText="Need an account?"
          footerLinkText="Sign up"
          footerLinkHref="/signup"
        />
      </div>
    </div>
  </main>
</MainLayout>
