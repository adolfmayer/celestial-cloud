---
import AuthCard from "../components/AuthCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Eventio | Log In">
  <main class="flex min-h-screen items-center px-4 py-12 sm:px-6">
    <div class="mx-auto w-full max-w-5xl">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <section>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-violet-600">LOG IN</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Join your next event in seconds.</h2>
          <p class="mt-3 max-w-md text-sm text-slate-600 sm:text-base">
            Static V1 of the Eventio sign-in flow mapped to Figma screens 01-1-1 and 01-1-2.
          </p>
        </section>
        <AuthCard
          title="Welcome back"
          subtitle="Log in to continue managing your events."
          cta="Log In"
          footerText="Need an account?"
          footerLinkText="Sign up"
          footerLinkHref="/signup"
        />
      </div>
    </div>
  </main>
</MainLayout>
