---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Eventio | Create New"
  description="Create a new event on Eventio with date, time, location, and details."
>
  <main class="min-h-screen px-4 py-8 sm:px-6">
    <section class="surface-card mx-auto w-full max-w-3xl p-6 sm:p-8">
      <p class="eyebrow">03-2-1-Create-New-Event</p>
      <h1 class="type-title mt-2">Create new event</h1>
      <form class="mt-6 grid gap-4 sm:grid-cols-2">
        <label class="block text-sm font-medium text-slate-700 sm:col-span-2">Event name
          <input type="text" class="field-input mt-1" placeholder="Design Community Meetup" />
        </label>
        <label class="block text-sm font-medium text-slate-700">Date
          <input type="text" class="field-input mt-1" placeholder="DD/MM/YYYY" />
        </label>
        <label class="block text-sm font-medium text-slate-700">Time
          <input type="text" class="field-input mt-1" placeholder="19:00" />
        </label>
        <label class="block text-sm font-medium text-slate-700 sm:col-span-2">Location
          <input type="text" class="field-input mt-1" placeholder="Brno, Czechia" />
        </label>
        <label class="block text-sm font-medium text-slate-700 sm:col-span-2">Description
          <textarea class="field-input mt-1 min-h-28" placeholder="Write event details..."></textarea>
        </label>
        <div class="sm:col-span-2">
          <button type="button" class="primary-btn px-4 py-3 text-sm font-semibold">Create Event</button>
        </div>
      </form>
    </section>
  </main>
</MainLayout>
