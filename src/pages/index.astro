---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Eventio - Static V1">
  <main class="flex min-h-screen items-center justify-center px-4 py-12">
    <section class="surface-card w-full max-w-2xl p-6 sm:p-8">
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Eventio Static V1</h1>
      <p class="mt-2 text-sm text-slate-600">
        Navigate the static routes that mirror your Figma flows.
      </p>
      <ul class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/login">Log In</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/signup">Sign Up</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/dashboard">Dashboard</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/dashboard-list">Dashboard List View</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/dashboard-detail">Dashboard Detail</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/dashboard-detail-joined">Dashboard Detail Joined</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/dashboard-detail-edit">Dashboard Detail Edit</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/create-new">Create New</a></li>
        <li><a class="block rounded-md border border-slate-200 px-4 py-3 font-medium text-slate-700 hover:bg-slate-50" href="/profile">Profile</a></li>
      </ul>
    </section>
  </main>
</MainLayout>
