---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Eventio | Dashboard Detail Joined"
  description="View event details, join events, and manage your participation."
>
  <main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-6xl">
      <div class="mb-4 inline-flex rounded-md border border-slate-200 bg-white p-1 text-xs font-semibold sm:text-sm">
        <a href="/dashboard-detail" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-1-Detail</a>
        <span class="primary-btn rounded-md px-3 py-2">03-1-2-Detail-Joined</span>
        <a href="/dashboard-detail-edit" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-3-Detail-Edit</a>
      </div>
    </div>
    <div class="mx-auto grid w-full max-w-6xl gap-6 lg:grid-cols-[2fr_1fr]">
      <section class="surface-card p-5 sm:p-7">
        <p class="eyebrow">Joined state</p>
        <h1 class="type-title mt-2">Summer Product Festival</h1>
        <p class="type-body mt-3 text-slate-600">
          You are already in. Event reminders and updates are now enabled for this profile.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <button type="button" class="rounded-xl border border-emerald-300 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-700">Joined</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Leave Event</button>
          <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Back to Dashboard</button>
        </div>
      </section>
      <aside class="surface-card p-5">
        <h2 class="text-lg font-semibold">Event facts</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>Date: 14 Aug 2026</li>
          <li>Time: 17:00</li>
          <li>Location: Vienna</li>
          <li>Status: Joined</li>
        </ul>
      </aside>
    </div>
  </main>
</MainLayout>
