---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Eventio | Sign Up">
  <main class="flex min-h-screen items-center px-4 py-12 sm:px-6">
    <div class="mx-auto grid w-full max-w-5xl items-center gap-10 lg:grid-cols-2">
      <section>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-violet-600">SIGN UP</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Create your Eventio profile.</h2>
        <p class="mt-3 max-w-md text-sm text-slate-600 sm:text-base">
          Static V1 mapped to Figma frame 01-3-1-Sign-Up.
        </p>
      </section>

      <section class="surface-card p-6 sm:p-8">
        <h1 class="text-2xl font-semibold tracking-tight">Get started</h1>
        <p class="mt-2 text-sm text-slate-500">Set up your account in less than a minute.</p>
        <form class="mt-6 space-y-4">
          <label class="block text-sm font-medium text-slate-700">Full Name
            <input type="text" class="mt-1 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100" placeholder="Ada Lovelace" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Email
            <input type="email" class="mt-1 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100" placeholder="ada@example.com" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Password
            <input type="password" class="mt-1 w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100" placeholder="********" />
          </label>
          <button type="button" class="w-full rounded-xl bg-violet-700 px-4 py-3 text-sm font-semibold text-white hover:bg-violet-800">Create Account</button>
        </form>
        <p class="mt-6 text-center text-sm text-slate-500">
          Already have an account?
          <a class="ml-1 font-semibold text-violet-700 hover:text-violet-800" href="/login">Log in</a>
        </p>
      </section>
    </div>
  </main>
</MainLayout>
