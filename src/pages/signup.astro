---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Eventio | Sign Up"
  description="Create your Eventio account to start joining and creating events."
>
  <main class="flex min-h-screen items-center px-4 py-12 sm:px-6">
    <div class="mx-auto grid w-full max-w-5xl items-center gap-10 lg:grid-cols-2">
      <section>
        <p class="eyebrow">SIGN UP</p>
        <h2 class="type-hero mt-4">Create your Eventio profile.</h2>
        <p class="type-body mt-3 max-w-md text-slate-600">Build your attendee identity and start joining events instantly.</p>
        <span class="mt-7 inline-block rounded-full bg-white px-3 py-1.5 text-xs font-semibold text-slate-500">01-3-1-Sign-Up</span>
      </section>

      <section class="surface-card p-6 sm:p-8">
        <h1 class="type-title">Get started</h1>
        <p class="mt-2 text-sm text-slate-500">Set up your account in less than a minute.</p>
        <form class="mt-6 space-y-4">
          <label class="block text-sm font-medium text-slate-700">Full Name
            <input type="text" class="field-input mt-1" placeholder="Ada Lovelace" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Email
            <input type="email" class="field-input mt-1" placeholder="ada@example.com" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Password
            <input type="password" class="field-input mt-1" placeholder="********" />
          </label>
          <button type="button" class="primary-btn w-full px-4 py-3 text-sm font-semibold">Create Account</button>
        </form>
        <p class="mt-6 text-center text-sm text-slate-500">
          Already have an account?
          <a class="link-brand ml-1 font-semibold" href="/login">Log in</a>
        </p>
      </section>
    </div>
  </main>
</MainLayout>
