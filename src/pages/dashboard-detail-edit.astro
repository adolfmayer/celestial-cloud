---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Eventio | Dashboard Detail Edit"
  description="View event details, join events, and manage your participation."
>
  <main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-6xl">
      <div class="mb-4 inline-flex rounded-md border border-slate-200 bg-white p-1 text-xs font-semibold sm:text-sm">
        <a href="/dashboard-detail" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-1-Detail</a>
        <a href="/dashboard-detail-joined" class="rounded-lg px-3 py-2 text-slate-600 hover:bg-slate-50">03-1-2-Detail-Joined</a>
        <span class="primary-btn rounded-md px-3 py-2">03-1-3-Detail-Edit</span>
      </div>
    </div>
    <div class="mx-auto grid w-full max-w-6xl gap-6 lg:grid-cols-[2fr_1fr]">
      <section class="surface-card p-5 sm:p-7">
        <p class="eyebrow">Edit state</p>
        <h1 class="type-title mt-2">Edit event details</h1>
        <form class="mt-5 grid gap-4 sm:grid-cols-2">
          <label class="block text-sm font-medium text-slate-700 sm:col-span-2">Event name
            <input class="field-input mt-1" type="text" value="Summer Product Festival" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Date
            <input class="field-input mt-1" type="text" value="14/08/2026" />
          </label>
          <label class="block text-sm font-medium text-slate-700">Time
            <input class="field-input mt-1" type="text" value="17:00" />
          </label>
          <label class="block text-sm font-medium text-slate-700 sm:col-span-2">Description
            <textarea class="field-input mt-1 min-h-28">A full day of talks, networking, and workshops.</textarea>
          </label>
          <div class="sm:col-span-2 flex flex-wrap gap-2">
            <button type="button" class="primary-btn px-4 py-2 text-sm font-semibold">Save changes</button>
            <button type="button" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700">Discard</button>
          </div>
        </form>
      </section>
      <aside class="surface-card p-5">
        <h2 class="text-lg font-semibold">Edit notes</h2>
        <p class="mt-3 text-sm text-slate-600">This static screen mirrors the edit variant without persistence logic.</p>
      </aside>
    </div>
  </main>
</MainLayout>
