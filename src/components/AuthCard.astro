---
interface Props {
  title: string;
  subtitle: string;
  cta: string;
  footerText: string;
  footerLinkText: string;
  footerLinkHref: string;
}

const {
  title,
  subtitle,
  cta,
  footerText,
  footerLinkText,
  footerLinkHref
} = Astro.props;
---

<section class="surface-card mx-auto w-full max-w-md p-6 sm:p-8">
  <h1 class="type-title">{title}</h1>
  <p class="type-body mt-2 text-slate-500">{subtitle}</p>

  <form class="mt-6 space-y-4">
    <label class="block text-sm font-medium text-slate-700">
      Email
      <input
        type="email"
        placeholder="you@example.com"
        class="field-input mt-1"
      />
    </label>

    <label class="block text-sm font-medium text-slate-700">
      Password
      <input
        type="password"
        placeholder="********"
        class="field-input mt-1"
      />
    </label>

    <button type="button" class="primary-btn w-full px-4 py-3 text-sm font-semibold">
      {cta}
    </button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-500">
    {footerText}
    <a class="link-brand ml-1 font-semibold" href={footerLinkHref}>
      {footerLinkText}
    </a>
  </p>
</section>
