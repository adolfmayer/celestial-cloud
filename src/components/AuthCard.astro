---
interface Props {
  title: string;
  subtitle: string;
  cta: string;
  footerText: string;
  footerLinkText: string;
  footerLinkHref: string;
}

const {
  title,
  subtitle,
  cta,
  footerText,
  footerLinkText,
  footerLinkHref
} = Astro.props;
---

<section class="surface-card mx-auto w-full max-w-md p-6 sm:p-8">
  <h1 class="text-2xl font-semibold tracking-tight">{title}</h1>
  <p class="mt-2 text-sm text-slate-500">{subtitle}</p>

  <form class="mt-6 space-y-4">
    <label class="block text-sm font-medium text-slate-700">
      Email
      <input
        type="email"
        placeholder="you@example.com"
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-violet-500 focus:ring-2 focus:ring-violet-100"
      />
    </label>

    <label class="block text-sm font-medium text-slate-700">
      Password
      <input
        type="password"
        placeholder="********"
        class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition focus:border-violet-500 focus:ring-2 focus:ring-violet-100"
      />
    </label>

    <button
      type="button"
      class="w-full rounded-xl bg-violet-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-violet-800"
    >
      {cta}
    </button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-500">
    {footerText}
    <a class="ml-1 font-semibold text-violet-700 hover:text-violet-800" href={footerLinkHref}>
      {footerLinkText}
    </a>
  </p>
</section>
