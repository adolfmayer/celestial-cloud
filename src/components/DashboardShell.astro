---
interface Props {
  title: string;
  subtitle?: string;
  listView?: boolean;
  showSubtitle?: boolean;
}

const { title, subtitle = "", listView = false, showSubtitle = false } = Astro.props;
---

<main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
  <div class="mx-auto w-full max-w-6xl">
    <header class="surface-card mb-6 p-4 sm:p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="eyebrow">Eventio</p>
          <h1 class="type-title mt-1">{title}</h1>
          {showSubtitle && subtitle && <p class="type-body mt-1 text-slate-500">{subtitle}</p>}
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <button
            class="rounded-md border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm"
            type="button"
          >
            SHOW: ALL EVENTS
          </button>
          <button
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition",
              listView ? "primary-btn" : "border border-slate-200 bg-white text-slate-700 shadow-sm"
            ]}
            type="button"
          >
            List View
          </button>
          <button
            class:list={[
              "rounded-md px-4 py-2 text-sm font-medium transition",
              listView ? "border border-slate-200 bg-white text-slate-700 shadow-sm" : "primary-btn"
            ]}
            type="button"
          >
            Grid View
          </button>
        </div>
      </div>
    </header>

    <slot />
  </div>
</main>
