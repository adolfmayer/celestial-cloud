---
interface Props {
  title: string;
  subtitle?: string;
  listView?: boolean;
}

const { title, subtitle = "", listView = false } = Astro.props;
---

<main class="min-h-screen px-4 py-6 sm:px-6 lg:px-10">
  <div class="mx-auto w-full max-w-6xl">
    <header class="surface-card mb-6 p-4 sm:p-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-violet-600">Eventio</p>
          <h1 class="mt-1 text-xl font-semibold sm:text-2xl">{title}</h1>
          {subtitle && <p class="mt-1 text-sm text-slate-500">{subtitle}</p>}
        </div>

        <div class="flex flex-wrap items-center gap-2">
          <button
            class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700"
            type="button"
          >
            SHOW: All Events
          </button>
          <button
            class:list={[
              "rounded-xl px-4 py-2 text-sm font-medium transition",
              listView ? "bg-violet-700 text-white" : "border border-slate-200 bg-white text-slate-700"
            ]}
            type="button"
          >
            List View
          </button>
          <button
            class:list={[
              "rounded-xl px-4 py-2 text-sm font-medium transition",
              listView ? "border border-slate-200 bg-white text-slate-700" : "bg-violet-700 text-white"
            ]}
            type="button"
          >
            Grid View
          </button>
        </div>
      </div>
    </header>

    <slot />
  </div>
</main>
